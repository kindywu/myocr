<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/drug_entry_background"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:background="@color/surface_card">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/abc_action_bar_up_description"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/completion_title"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 进度概览 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/progressText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="12dp"
                        app:indicatorColor="@color/brand_500"
                        app:trackColor="@color/brand_100"
                        app:trackThickness="6dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 字段状态列表 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="识别详情"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <!-- 药品名称 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/drugNameCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_drug_name"
                            android:textSize="13sp"
                            android:textColor="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/drugNameValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/drugNameCapture"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_capture_small"
                        android:contentDescription="@string/continue_capture"
                        android:background="@drawable/circle_brand_bg"
                        android:padding="6dp"
                        android:tint="@color/brand_500"
                        android:visibility="visible" />

                    <ImageButton
                        android:id="@+id/drugNameVoice"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_mic"
                        android:contentDescription="@string/voice_input_label"
                        android:background="@drawable/circle_brand_bg"
                        android:padding="6dp"
                        android:tint="@color/brand_500"
                        android:visibility="visible" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 有效期至 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/expiryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_expiry_date"
                            android:textSize="13sp"
                            android:textColor="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/expiryValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/expiryCapture"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_capture_small"
                        android:contentDescription="@string/continue_capture"
                        android:background="@drawable/circle_brand_bg"
                        android:padding="6dp"
                        android:tint="@color/brand_500" />

                    <ImageButton
                        android:id="@+id/expiryVoice"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_mic"
                        android:contentDescription="@string/voice_input_label"
                        android:background="@drawable/circle_brand_bg"
                        android:padding="6dp"
                        android:tint="@color/brand_500" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 生产厂家 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/manufacturerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_manufacturer"
                            android:textSize="13sp"
                            android:textColor="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/manufacturerValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/manufacturerCapture"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_capture_small"
                        android:contentDescription="@string/continue_capture"
                        android:background="@drawable/circle_brand_bg"
                        android:padding="6dp"
                        android:tint="@color/brand_500" />

                    <ImageButton
                        android:id="@+id/manufacturerVoice"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_mic"
                        android:contentDescription="@string/voice_input_label"
                        android:background="@drawable/circle_brand_bg"
                        android:padding="6dp"
                        android:tint="@color/brand_500" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 批号 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/batchCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_batch_number"
                            android:textSize="13sp"
                            android:textColor="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/batchValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/batchCapture"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_capture_small"
                        android:contentDescription="@string/continue_capture"
                        android:background="@drawable/circle_brand_bg"
                        android:padding="6dp"
                        android:tint="@color/brand_500" />

                    <ImageButton
                        android:id="@+id/batchVoice"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_mic"
                        android:contentDescription="@string/voice_input_label"
                        android:background="@drawable/circle_brand_bg"
                        android:padding="6dp"
                        android:tint="@color/brand_500" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 调试：查看识别调试信息（OCR+LLM+语音） -->
            <TextView
                android:id="@+id/debugRawOcr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/view_raw_ocr"
                android:textSize="13sp"
                android:textColor="@color/brand_500"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp" />

        </LinearLayout>

    </ScrollView>

    <!-- 底部操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:background="@color/surface_card"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/continueCaptureButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/continue_capture"
            android:textColor="@color/brand_500"
            app:strokeColor="@color/brand_500" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewResultButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/view_result"
            android:backgroundTint="@color/brand_500" />

    </LinearLayout>

</LinearLayout>
