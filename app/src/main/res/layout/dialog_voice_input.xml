<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    android:clickable="true">

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@drawable/voice_input_bg"
        android:padding="32dp"
        android:elevation="16dp">

        <!-- 脉冲动画环 + 麦克风 -->
        <FrameLayout
            android:id="@+id/micContainer"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="20dp">

            <!-- 脉冲环1（外层，动画缩放） -->
            <View
                android:id="@+id/pulseRing1"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/voice_input_pulse_ring"
                android:alpha="0.3" />

            <!-- 脉冲环2（内层，动画缩放） -->
            <View
                android:id="@+id/pulseRing2"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/voice_input_pulse_ring"
                android:alpha="0.15" />

            <!-- 麦克风图标 -->
            <ImageButton
                android:id="@+id/micIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic_active"
                android:background="@drawable/circle_brand_bg"
                android:padding="10dp"
                android:clickable="false"
                android:focusable="false"
                android:contentDescription="@string/voice_input_label" />

        </FrameLayout>

        <!-- "正在聆听..." 提示 -->
        <TextView
            android:id="@+id/listeningHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_listening"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- 字段标签提示 -->
        <TextView
            android:id="@+id/fieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginBottom="16dp" />

        <!-- 音波可视化（振幅条） -->
        <LinearLayout
            android:id="@+id/waveContainer"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- 动态生成 5 个振幅条 -->
            <View
                android:id="@+id/waveBar1"
                android:layout_width="6dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/voice_input_pulse_ring" />
            <View
                android:id="@+id/waveBar2"
                android:layout_width="6dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/voice_input_pulse_ring" />
            <View
                android:id="@+id/waveBar3"
                android:layout_width="6dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/voice_input_pulse_ring" />
            <View
                android:id="@+id/waveBar4"
                android:layout_width="6dp"
                android:layout_height="20dp"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/voice_input_pulse_ring" />
            <View
                android:id="@+id/waveBar5"
                android:layout_width="6dp"
                android:layout_height="28dp"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/voice_input_pulse_ring" />

        </LinearLayout>

        <!-- 实时识别文字 -->
        <TextView
            android:id="@+id/partialResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:minLines="1"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="20dp" />

        <!-- 取消按钮 -->
        <Button
            android:id="@+id/cancelButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/voice_cancel"
            android:textColor="@color/brand_500"
            android:backgroundTint="@android:color/transparent"
            android:stateListAnimator="@null"
            style="@style/Widget.Material3.Button.TextButton" />

    </LinearLayout>

</FrameLayout>
