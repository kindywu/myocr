<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface_card">

    <!-- 拖动指示条 -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#DDD"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="分配字段"
        android:textSize="17sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="这行文字对应哪个字段？"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/sheetSelectedText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:textStyle="normal"
        android:background="@drawable/circle_gray_bg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:layout_marginBottom="16dp"
        android:inputType="text"
        android:maxLines="3"
        android:minLines="1" />

    <!-- 字段选项 -->
    <LinearLayout
        android:id="@+id/sheetFieldDrugName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="💊"
            android:textSize="18sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/field_drug_name"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="药品的通用名称，如「布洛芬缓释胶囊」"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary" />

        </LinearLayout>

        <TextView
            android:id="@+id/sheetFieldDrugNameCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="✓"
            android:textSize="16sp"
            android:textColor="@color/brand_500"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color" />

    <LinearLayout
        android:id="@+id/sheetFieldExpiry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="📅"
            android:textSize="18sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/field_expiry_date"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="有效期或过期日期，如「2026-09」"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary" />

        </LinearLayout>

        <TextView
            android:id="@+id/sheetFieldExpiryCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="✓"
            android:textSize="16sp"
            android:textColor="@color/brand_500"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color" />

    <LinearLayout
        android:id="@+id/sheetFieldManufacturer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="🏭"
            android:textSize="18sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/field_manufacturer"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="制药企业名称，如「中美天津史克制药」"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary" />

        </LinearLayout>

        <TextView
            android:id="@+id/sheetFieldManufacturerCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="✓"
            android:textSize="16sp"
            android:textColor="@color/brand_500"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color" />

    <LinearLayout
        android:id="@+id/sheetFieldBatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="🔢"
            android:textSize="18sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/field_batch_number"
                android:textSize="15sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="生产批号 / Lot No."
                android:textSize="12sp"
                android:textColor="@color/text_tertiary" />

        </LinearLayout>

        <TextView
            android:id="@+id/sheetFieldBatchCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="✓"
            android:textSize="16sp"
            android:textColor="@color/brand_500"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/sheetConfirmButton"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="确定"
        android:backgroundTint="@color/brand_500" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/sheetUnassignButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="清除分配"
        android:textColor="@color/text_tertiary"
        android:visibility="gone" />

</LinearLayout>
