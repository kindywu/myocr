<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/drug_entry_background"
    android:orientation="vertical">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:background="@color/surface_card">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/abc_action_bar_up_description"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选择识别内容"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/stepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3/5"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- AI 自动填写卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/aiAutoFillCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/brand_500"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="🤖"
                        android:textSize="24sp"
                        android:gravity="center"
                        android:background="@android:color/transparent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI 智能提取全部字段"
                            android:textSize="17sp"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="自动填写药品名称、有效期、厂家和批号"
                            android:textSize="13sp"
                            android:textColor="@android:color/white"
                            android:alpha="0.85"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="20sp"
                        android:textColor="@android:color/white"
                        android:alpha="0.8" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 手动选择区域 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="或手动选择"
                android:textSize="13sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="10dp"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OCR 识别结果"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/ocrLineContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- 摘要 -->
            <LinearLayout
                android:id="@+id/summaryBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/brand_100"
                android:padding="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/summaryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ 已分配 0/4 个字段"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- 字段列表 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="字段分配"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fieldDrugNameCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:id="@+id/fieldDrugName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/fieldDrugNameIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="💊"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_drug_name"
                            android:textSize="12sp"
                            android:textColor="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/fieldDrugNameValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击上方文字行分配…"
                            android:textSize="15sp"
                            android:textColor="@color/text_tertiary"
                            android:textStyle="italic" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/fieldDrugNameClear"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_close"
                        android:contentDescription="清除"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="@color/text_tertiary"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fieldExpiryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:id="@+id/fieldExpiry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/fieldExpiryIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="📅"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_expiry_date"
                            android:textSize="12sp"
                            android:textColor="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/fieldExpiryValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击上方文字行分配…"
                            android:textSize="15sp"
                            android:textColor="@color/text_tertiary"
                            android:textStyle="italic" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/fieldExpiryClear"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_close"
                        android:contentDescription="清除"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="@color/text_tertiary"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fieldManufacturerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:id="@+id/fieldManufacturer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/fieldManufacturerIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="🏭"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_manufacturer"
                            android:textSize="12sp"
                            android:textColor="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/fieldManufacturerValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击上方文字行分配…"
                            android:textSize="15sp"
                            android:textColor="@color/text_tertiary"
                            android:textStyle="italic" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/fieldManufacturerClear"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_close"
                        android:contentDescription="清除"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="@color/text_tertiary"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/fieldBatchCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_card"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color">

                <LinearLayout
                    android:id="@+id/fieldBatch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/fieldBatchIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="🔢"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/field_batch_number"
                            android:textSize="12sp"
                            android:textColor="@color/text_tertiary" />

                        <TextView
                            android:id="@+id/fieldBatchValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击上方文字行分配…"
                            android:textSize="15sp"
                            android:textColor="@color/text_tertiary"
                            android:textStyle="italic" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/fieldBatchClear"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_close"
                        android:contentDescription="清除"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="@color/text_tertiary"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:background="@color/surface_card"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/skipButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="跳过（规则提取）"
                android:textColor="@color/text_tertiary"
                app:strokeColor="@color/divider_color" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/confirmButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="确认并继续"
                android:backgroundTint="@color/brand_500"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
